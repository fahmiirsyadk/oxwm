all::
#if InstallSampleRC
             SRC_CONFIG = Oxwmrc

                SAMPLES = Oxwmrc-Xterm \
                          Oxwmrc-Kterm-j \
                          Oxwmrc-Netscape \
                          Oxwmrc-j

InstallNamedNonExec($(SRC_CONFIG),system$(OXWMRC),$(OXWMLIBDIR))
InstallMultiple($(SAMPLES),$(OXWMLIBDIR))
#endif
